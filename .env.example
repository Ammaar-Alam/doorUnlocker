PORT=
THING_ID=
PROPERTY_ID=
CLIENT_ID=
CLIENT_SECRET=
PASSWORD=
SECRET_KEY=
AUTH_REQUIRED=
# Optional JWT auth token lifetime in seconds (default 86400 = 24h)
AUTH_TOKEN_TTL_SECONDS=
# Optional Arduino API timeout in ms (default 10000)
ARDUINO_HTTP_TIMEOUT_MS=
# Optional background status poll interval in ms (default 5000)
STATUS_POLL_INTERVAL_MS=
# Optional optimistic UI settle window in ms after a command (default 6000)
COMMAND_SETTLE_MS=
# Admin token used by GitHub Actions to toggle auth on/off
ADMIN_TOKEN=

# --- ntfy notifications (used by /ring-doorbell) ---
# Base URL for ntfy (defaults to https://ntfy.sh if unset)
NTFY_URL=
# Topic to publish doorbell notifications to (required for /ring-doorbell)
NTFY_TOPIC=
